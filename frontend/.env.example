# Frontend environment variables (Vite)
# Copy this file to `.env` and fill in the values. NEVER commit a real `.env`.
#
# Supabase project URL (project ref: mlnhocdsbwlaeqemluvp)
VITE_SUPABASE_URL=

# Supabase PUBLIC anon key — safe to expose in the browser.
# Use ONLY the public anon key here. NEVER put the service-role key in the
# frontend; it bypasses Row Level Security and must stay server-side.
VITE_SUPABASE_ANON_KEY=
