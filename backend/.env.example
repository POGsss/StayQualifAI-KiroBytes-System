# StayQualifAI backend environment variables (copy to .env, never commit .env)
PORT=3000

# Supabase (project ref: mlnhocdsbwlaeqemluvp)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (free tier)
GEMINI_API_KEY=
# Optional fallback key(s) tried in order when the primary hits a rate limit /
# quota (HTTP 429). Any that are set are used; leave blank if you have only one.
OPENAI_API_KEY=
GROQ_API_KEY=
# Optional: comma-separated list of keys (highest priority; overrides the above order).
# GEMINI_API_KEYS=key1,key2,key3
# Optional model override (default: gemini-flash-latest).
# GEMINI_MODEL=gemini-flash-latest
