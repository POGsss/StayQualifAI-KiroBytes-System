{
  "name": "@stayqualifai/backend",
  "version": "0.1.0",
  "private": true,
  "description": "StayQualifAI Express API (Module 1: Resume)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/generative-ai": "0.21.0",
    "@supabase/supabase-js": "2.47.10",
    "express": "4.21.2",
    "mammoth": "1.8.0",
    "multer": "2.2.0",
    "pdf-parse": "1.1.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/express": "4.17.21",
    "@types/multer": "2.1.0",
    "@types/node": "22.10.5",
    "@types/pdf-parse": "1.1.4",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.31.0",
    "fast-check": "3.23.2",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.19.1",
    "vitest": "2.1.8"
  }
}
